# =============================================================================
# Notaria Notary — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in values for your environment.
#   cp .env.example .env
#
# Production: set DJANGO_DEBUG=false, use PostgreSQL, and configure email + HTTPS.
# Local dev:   set DJANGO_DEBUG=true (SQLite is used when DATABASE_URL is empty).
# =============================================================================

# --- Core Django (required in production) ---

# Long random string. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret

# true = development | false = production
DJANGO_DEBUG=true

# Comma-separated hostnames (no scheme). Example: localhost,127.0.0.1,notary.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Public site URL with scheme, no trailing slash. Required when DJANGO_DEBUG=false.
# Used for SEO canonical URLs, sitemap links, and email content.
SITE_URL=http://localhost:8000

# Comma-separated HTTPS origins for CSRF (required behind HTTPS in production).
# Example: https://notary.example.com,https://www.notary.example.com
CSRF_TRUSTED_ORIGINS=

# --- Database ---

# PostgreSQL connection URL (required when DJANGO_DEBUG=false).
# Example: postgres://notary:secret@localhost:5432/notary
# Railway/Render: add a Postgres service — do not leave this empty if you set it manually.
# Also accepted: POSTGRES_URL, DATABASE_PRIVATE_URL, or PGHOST/PGUSER/PGPASSWORD/PGDATABASE.
DATABASE_URL=

# Demo only: allow SQLite when DJANGO_DEBUG=false (data is lost on redeploy without a volume).
# USE_SQLITE=true

# Persistent storage root for SQLite + uploads (mount a Docker/Coolify volume here).
# Default: /app/data (writable; /app itself is often read-only on PaaS hosts).
# Example: DATA_DIR=/app/data
# DATA_DIR=

# Persistent DB connections in seconds (PostgreSQL only). Default: 600
DATABASE_CONN_MAX_AGE=600

# Set true if your PostgreSQL provider requires SSL
DATABASE_SSL=false

# --- Static & media files ---

# URL prefixes (usually leave as defaults)
STATIC_URL=/static/
MEDIA_URL=/media/

# Filesystem paths relative to project root
STATIC_ROOT=staticfiles
MEDIA_ROOT=media

# --- Email (required in production for contact form & notifications) ---

CONTACT_EMAIL=office@notarianotary.com
DEFAULT_FROM_EMAIL=noreply@notarianotary.com
SERVER_EMAIL=noreply@notarianotary.com

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# --- Site branding ---

# Public theme: theme-1 (blue) | theme-2 (green) | theme-3 (violet)
SITE_THEME=theme-3

# Display currency symbol in staff finance views
CURRENCY=$

# Application timezone (IANA name)
TIME_ZONE=Africa/Mogadishu

# --- Features ---

# Allow public user registration at /account/register/
PUBLIC_AUTH_ENABLED=false

# Max document upload size in bytes (default 10 MB)
DOCUMENT_MAX_UPLOAD_SIZE=10485760

# --- Security (production / HTTPS) ---

# Redirect HTTP to HTTPS (default true when DJANGO_DEBUG=false)
SECURE_SSL_REDIRECT=true

# HSTS duration in seconds (default 1 year). Enable only when HTTPS is permanent.
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false

# Trust X-Forwarded-Proto from reverse proxy (nginx, Caddy, load balancer)
USE_PROXY_SSL_HEADER=true

# Session lifetime in seconds (default 12 hours)
SESSION_COOKIE_AGE=43200
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# --- Logging ---

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Gunicorn (optional overrides) ---

# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=120
